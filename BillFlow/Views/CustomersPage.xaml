<UserControl x:Class="BillFlow.Views.CustomersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Notifications and Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <Border Background="#FEF2F2" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="{StaticResource DangerBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="8,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border Background="#F0FDF4" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="{StaticResource SuccessBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" Margin="8,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource GlassCardStyle}" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Magnify" 
                                             Width="20" 
                                             Height="20"
                                             Foreground="{StaticResource Gray400Brush}"
                                             VerticalAlignment="Center"/>
                    <TextBox BorderThickness="0"
                             Background="Transparent"
                             Width="300"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             FontSize="14"
                             ToolTip="Search customers by name or phone..."
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <Button Grid.Column="1" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="+ Add Customer"
                    Margin="16,0,0,0"
                    Command="{Binding AddCustomerCommand}"/>
            </Grid>
        </StackPanel>

        <!-- Stats Bar -->
        <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,16" Padding="16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Total Customers: " Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="{Binding TotalCustomers}" Style="{StaticResource NumberStyle}" Margin="4,0,24,0"/>
                <TextBlock Text="With Credit: " Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="{Binding CustomersWithCredit}" Style="{StaticResource NumberStyle}" Margin="4,0,0,0" Foreground="{StaticResource WarningBrush}"/>
            </StackPanel>
        </Border>

        <!-- Loading Spinner -->
        <Border Grid.Row="2" 
                Style="{StaticResource GlassCardStyle}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="180" Height="6"/>
                    <TextBlock Text="Loading customers..." Margin="0,16,0,0" Foreground="{StaticResource Gray500Brush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2" 
                Style="{StaticResource GlassCardStyle}"
                Visibility="{Binding HasNoCustomers, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="48">
                <materialDesign:PackIcon Kind="AccountOff" Width="64" Height="64" Foreground="{StaticResource Gray300Brush}" HorizontalAlignment="Center"/>
                <TextBlock Text="No customers found" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Gray600Brush}" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                <TextBlock Text="Add your first customer to get started" FontSize="14" Foreground="{StaticResource Gray400Brush}" HorizontalAlignment="Center"/>
                <Button Content="Add Customer" Style="{StaticResource PrimaryButtonStyle}" Margin="0,24,0,0" HorizontalAlignment="Center" Command="{Binding AddCustomerCommand}"/>
            </StackPanel>
        </Border>

        <!-- Customers Data Grid -->
        <Border Grid.Row="2" 
                Style="{StaticResource GlassCardStyle}"
                Visibility="{Binding HasCustomers, Converter={StaticResource BoolToVisibilityConverter}}">
            <DataGrid AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      HeadersVisibility="Column"
                      Background="Transparent"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{StaticResource Gray50Brush}"
                      ItemsSource="{Binding CustomersView}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CODE" Binding="{Binding CustomerCode}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="200"/>
                    <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                <Setter Property="Foreground" Value="{StaticResource Gray600Brush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="CREDIT LIMIT" Binding="{Binding CreditLimit, StringFormat='PKR {0:N0}'}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="BALANCE" Binding="{Binding TotalCredit, StringFormat='PKR {0:N0}'}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="RISK" Width="100"
                                            SortMemberPath="CreditRisk"
                                            CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding CreditRisk, Converter={StaticResource RiskToBrushConverter}}"
                                        CornerRadius="12"
                                        Padding="8,4"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding CreditRisk, Converter={StaticResource RiskToDisplayConverter}}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding CreditRisk, Converter={StaticResource RiskToForegroundConverter}}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="ACTIONS" Width="120"
                                            CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                            Padding="8"
                                            Command="{Binding DataContext.EditCustomerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                    </Button>
                                    <Button Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                            Padding="8"
                                            Margin="4,0,0,0"
                                            Command="{Binding DataContext.ViewCustomerDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Eye" Width="16" Height="16"/>
                                    </Button>
                                    <Button Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                            Padding="8"
                                            Margin="4,0,0,0"
                                            Foreground="{StaticResource DangerBrush}"
                                            Command="{Binding DataContext.DeleteCustomerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
