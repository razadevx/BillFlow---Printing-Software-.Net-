<UserControl x:Class="BillFlow.Views.WorkOrderCreatePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - Work Order Details -->
        <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="{Binding FormTitle}" Style="{StaticResource H2Style}" Margin="0,0,0,24"/>

                <!-- Customer & Date -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="CUSTOMER" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                        <Border Style="{StaticResource GlassCardStyle}" Padding="12">
                            <ComboBox ItemsSource="{Binding Customers}"
                                      SelectedItem="{Binding SelectedCustomer}"
                                      DisplayMemberPath="Name"
                                      MinHeight="40"
                                      Padding="8,4"
                                      FontSize="14"
                                      IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"/>
                        </Border>
                        <TextBlock Text="Loading customers..." 
                                   Foreground="{StaticResource Gray500Brush}"
                                   FontSize="12"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="SCHEDULED DATE" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                        <Border Style="{StaticResource GlassCardStyle}" Padding="12">
                            <DatePicker SelectedDate="{Binding ScheduledDate}" BorderThickness="0"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Line Items -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="LINE ITEMS" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="+ Add Item"
                                Command="{Binding AddLineItemCommand}"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LineItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GlassCardStyle}" Margin="0,0,0,8" Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Description -->
                                            <TextBox Grid.Row="0" Grid.Column="0"
                                                     Style="{StaticResource GlassInputStyle}"
                                                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,8,0"
                                                     ToolTip="Enter item description"/>

                                            <!-- Width -->
                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,0">
                                                <TextBlock Text="Width (ft)" Style="{StaticResource BodySmallStyle}" Margin="0,0,0,4"/>
                                                <TextBox Style="{StaticResource GlassInputStyle}"
                                                         Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="{StaticResource JetBrainsMonoFontFamily}"/>
                                            </StackPanel>

                                            <!-- Height -->
                                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,0">
                                                <TextBlock Text="Height (ft)" Style="{StaticResource BodySmallStyle}" Margin="0,0,0,4"/>
                                                <TextBox Style="{StaticResource GlassInputStyle}"
                                                         Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="{StaticResource JetBrainsMonoFontFamily}"/>
                                            </StackPanel>

                                            <!-- Quantity -->
                                            <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,8,0">
                                                <TextBlock Text="Qty" Style="{StaticResource BodySmallStyle}" Margin="0,0,0,4"/>
                                                <TextBox Style="{StaticResource GlassInputStyle}"
                                                         Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="{StaticResource JetBrainsMonoFontFamily}"/>
                                            </StackPanel>

                                            <!-- Total -->
                                            <StackPanel Grid.Row="0" Grid.Column="4">
                                                <TextBlock Text="Total" Style="{StaticResource BodySmallStyle}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Total, StringFormat='PKR {0:N2}'}" 
                                                           Style="{StaticResource NumberStyle}"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Delete Button -->
                                            <Button Grid.Row="0" Grid.Column="5"
                                                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                                    Padding="8"
                                                    Command="{Binding DataContext.RemoveLineItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="{StaticResource DangerBrush}"/>
                                            </Button>

                                            <!-- Area display -->
                                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                                       Margin="0,8,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} × {1} × {2} = {3:F1} SqFt">
                                                        <Binding Path="Width"/>
                                                        <Binding Path="Height"/>
                                                        <Binding Path="Quantity"/>
                                                        <Binding Path="Area"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodySmallStyle}">
                                                        <Setter Property="Foreground" Value="{StaticResource Gray500Brush}"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                    <Button Style="{StaticResource SecondaryButtonStyle}" 
                            Content="Cancel" 
                            Margin="0,0,8,0"
                            Command="{Binding CancelCommand}"/>
                    <Button Style="{StaticResource PrimaryButtonStyle}" 
                            Content="{Binding SubmitButtonText}"
                            Command="{Binding CreateWorkOrderCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel - Summary -->
        <Border Grid.Column="1" Style="{StaticResource GlassCardStyle}">
            <StackPanel>
                <TextBlock Text="Order Summary" Style="{StaticResource H3Style}" Margin="0,0,0,24"/>

                <!-- Summary Items -->
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Total SqFt:" Style="{StaticResource BodyStyle}"/>
                        <TextBlock Text="{Binding TotalArea, StringFormat='{}{0:F1}'}" 
                                   Style="{StaticResource NumberStyle}" 
                                   HorizontalAlignment="Right"
                                   FontFamily="{StaticResource JetBrainsMonoFontFamily}"/>
                    </Grid>

                    <Separator Background="{StaticResource Gray200Brush}" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Current Bill:" Style="{StaticResource BodyStyle}"/>
                        <TextBlock Text="{Binding CurrentBill, StringFormat='PKR {0:N0}'}" 
                                   Style="{StaticResource NumberStyle}" 
                                   HorizontalAlignment="Right"
                                   FontFamily="{StaticResource JetBrainsMonoFontFamily}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Past Bill:" Style="{StaticResource BodyStyle}"/>
                        <TextBlock Text="{Binding PastBill, StringFormat='PKR {0:N0}'}" 
                                   Style="{StaticResource NumberStyle}" 
                                   HorizontalAlignment="Right"
                                   FontFamily="{StaticResource JetBrainsMonoFontFamily}"
                                   Foreground="{StaticResource WarningBrush}"/>
                    </Grid>

                    <Separator Background="{StaticResource Gray200Brush}" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Grand Total:" Style="{StaticResource BodyStyle}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding GrandTotal, StringFormat='PKR {0:N0}'}" 
                                   Style="{StaticResource NumberStyle}" 
                                   HorizontalAlignment="Right"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Amount Paid:" Style="{StaticResource BodyStyle}"/>
                        <TextBox Style="{StaticResource GlassInputStyle}" 
                                 Text="{Binding AmountPaid, UpdateSourceTrigger=PropertyChanged}"
                                 Width="120"
                                 HorizontalAlignment="Right">
                            <TextBox.FontFamily>
                                <StaticResource ResourceKey="JetBrainsMonoFontFamily"/>
                            </TextBox.FontFamily>
                        </TextBox>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Pending:" Style="{StaticResource BodyStyle}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PendingAmount, StringFormat='PKR {0:N0}'}" 
                                   Style="{StaticResource NumberStyle}" 
                                   HorizontalAlignment="Right"
                                   Foreground="{StaticResource DangerBrush}"/>
                    </Grid>
                </StackPanel>

                <!-- Payment Status -->
                <StackPanel Margin="0,24,0,0">
                    <TextBlock Text="PAYMENT STATUS" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding PaymentStatuses}"
                              SelectedItem="{Binding SelectedPaymentStatus}"/>
                </StackPanel>

                <!-- Notes -->
                <StackPanel Margin="0,24,0,0">
                    <TextBlock Text="NOTES" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource GlassInputStyle}"
                             Text="{Binding Notes}"
                             Height="80"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
