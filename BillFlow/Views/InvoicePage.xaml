<UserControl x:Class="BillFlow.Views.InvoicePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,24">
            <TextBlock Text="Invoice Generator" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}" FontFamily="{StaticResource InterFontFamily}"/>
            <TextBlock Text="Create and print invoices for your customers." FontSize="14" Foreground="{StaticResource Gray500Brush}" Margin="0,8,0,0" FontFamily="{StaticResource InterFontFamily}"/>
        </StackPanel>

        <!-- Notifications -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,16">
            <Border Background="#FEF2F2" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="{StaticResource DangerBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="8,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border Background="#F0FDF4" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="{StaticResource SuccessBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" Margin="8,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Left Panel - Customer & Work Order Selection -->
        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Generate Invoice" Style="{StaticResource H3Style}" Margin="0,0,0,16"/>

                <!-- Customer Selector -->
                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <TextBlock Text="SELECT CUSTOMER" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource GlassCardStyle}" Padding="12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Account" Width="20" Height="20" Foreground="{StaticResource PrimaryBrush}"/>
                            <ComboBox ItemsSource="{Binding Customers}"
                                      SelectedItem="{Binding SelectedCustomer, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="Name"
                                      Width="240"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      Margin="8,0,0,0">
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    
                    <Button Content="Print Account Statement"
                            Command="{Binding GenerateStatementCommand}"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="{StaticResource Gray400Brush}"
                            BorderThickness="1.5"
                            Padding="12,8">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountDetails" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>

                <!-- Work Orders List -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="PENDING WORK ORDERS" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                    <ScrollViewer Style="{StaticResource ModernScrollViewerStyle}" Height="200">
                        <ListBox ItemsSource="{Binding PendingWorkOrders}"
                                 SelectedItem="{Binding SelectedWorkOrder, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,4" Padding="8" Background="#F5F5F5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OrderCode}" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,2,0,0" FontSize="11" Text="{Binding TotalArea, StringFormat={}{0:F1} SqFt}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </StackPanel>

                <!-- Generate Button -->
                <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,16,0,0">
                    <Button Content="Generate Invoice"
                            Command="{Binding GenerateInvoiceCommand}"
                            Margin="0,0,0,8"
                            Background="{StaticResource PrimaryBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="24,10"/>
                    <Button Content="Generate Customer Statement"
                            Command="{Binding GenerateStatementCommand}"
                            Background="Transparent"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1.5"
                            Padding="24,10"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel - Invoice Preview -->
        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource GlassCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Invoice Preview" Style="{StaticResource H3Style}" Margin="0,0,0,16"/>

                <!-- Invoice Paper -->
                <Border Grid.Row="1" 
                        Background="White" 
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Padding="32">
                    <StackPanel>
                        <TextBlock Text="INVOICE PREVIEW" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                        
                        <TextBlock FontSize="14" Margin="0,0,0,8">
                            <Run Text="Customer: "/>
                            <Run Text="{Binding SelectedCustomer.Name, TargetNullValue='-'}" FontWeight="SemiBold"/>
                        </TextBlock>

                        <TextBlock FontSize="14" Margin="0,0,0,8">
                            <Run Text="Order: "/>
                            <Run Text="{Binding SelectedWorkOrder.OrderCode, TargetNullValue='-'}" FontWeight="SemiBold"/>
                        </TextBlock>

                        <Separator Margin="0,12"/>

                        <Grid Margin="0,12,0,4">
                            <TextBlock Text="Total Area:" TextAlignment="Left"/>
                            <TextBlock Text="{Binding SelectedWorkOrder.TotalArea, StringFormat={}{0:F1} SqFt}" TextAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Current Bill:" TextAlignment="Left"/>
                            <TextBlock Text="{Binding SelectedWorkOrder.TotalAmount, StringFormat='PKR {0:N2}'}" TextAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Past Bill:" TextAlignment="Left"/>
                            <TextBlock Text="{Binding SelectedWorkOrder.PastBill, StringFormat='PKR {0:N2}'}" TextAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Grand Total:" FontWeight="Bold" TextAlignment="Left"/>
                            <TextBlock Text="{Binding SelectedWorkOrder.GrandTotal, StringFormat='PKR {0:N2}'}" FontWeight="Bold" TextAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Amount Paid:" TextAlignment="Left"/>
                            <TextBlock Text="{Binding SelectedWorkOrder.AmountPaid, StringFormat='PKR {0:N2}'}" TextAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Pending:" FontWeight="Bold" TextAlignment="Left"/>
                            <TextBlock Text="{Binding SelectedWorkOrder.PendingAmount, StringFormat='PKR {0:N2}'}" FontWeight="Bold" TextAlignment="Right" Foreground="#F43F5E"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Command="{Binding GenerateInvoiceCommand}"
                            Margin="0,0,8,0"
                            Background="White"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1.5"
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FilePdfBox" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Export PDF"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
