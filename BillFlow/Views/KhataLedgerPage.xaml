<UserControl x:Class="BillFlow.Views.KhataLedgerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Khata Ledger" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}" FontFamily="{StaticResource InterFontFamily}"/>
            <TextBlock Text="Track customer credit, payments, and outstanding balances." FontSize="14" Foreground="{StaticResource Gray500Brush}" Margin="0,8,0,0" FontFamily="{StaticResource InterFontFamily}"/>
        </StackPanel>

        <!-- Notifications and Banner -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <!-- Notifications -->
            <Border Background="#FEF2F2" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="{StaticResource DangerBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="8,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border Background="#F0FDF4" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="{StaticResource SuccessBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" Margin="8,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        <!-- Total Pending Banner -->
        <Border Style="{StaticResource GlassCardStyle}"
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource PrimaryDarkBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="TOTAL PENDING ACROSS ALL CUSTOMERS" 
                               Style="{StaticResource LabelStyle}"
                               Foreground="White"
                               Opacity="0.8"/>
                    <TextBlock Text="{Binding TotalPending, StringFormat='PKR {0:N0}'}" 
                               Style="{StaticResource CurrencyStyle}"
                               Foreground="White"
                               Margin="0,8,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Background="White"
                        BorderBrush="White"
                        Foreground="#4F46E5"
                        Content="Record Payment"
                        VerticalAlignment="Center"
                        Padding="24,10"
                        FontWeight="SemiBold"
                        BorderThickness="1.5"
                        Command="{Binding RecordPaymentCommand}"
                        CommandParameter="{Binding SelectedSummary}"/>
            </Grid>
        </Border>
        </StackPanel>

        <!-- Customer Selector and Stats -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource GlassCardStyle}" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Account" 
                                             Width="20" 
                                             Height="20"
                                             Foreground="{StaticResource PrimaryBrush}"
                                             VerticalAlignment="Center"/>
                    <ComboBox Width="250"
                              BorderThickness="0"
                              Background="Transparent"
                              Margin="8,0,0,0"
                              ItemsSource="{Binding CustomerSummaries}"
                              SelectedItem="{Binding SelectedSummary}"
                              DisplayMemberPath="Customer.Name"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Style="{StaticResource GlassCardStyle}" Padding="16,8" Margin="8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Credit: " Style="{StaticResource BodyStyle}"/>
                        <TextBlock Text="{Binding TotalPending, StringFormat='PKR {0:N0}'}" Style="{StaticResource NumberStyle}" Foreground="{StaticResource DangerBrush}" Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassCardStyle}" Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Paid Today: " Style="{StaticResource BodyStyle}"/>
                        <TextBlock Text="{Binding TotalPaidToday, StringFormat='PKR {0:N0}'}" Style="{StaticResource NumberStyle}" Foreground="{StaticResource SuccessBrush}" Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Credit Summary Table -->
        <Border Grid.Row="3" Style="{StaticResource GlassCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Credit Summary" Style="{StaticResource H3Style}" Margin="0,0,0,16"/>

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          Background="Transparent"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{StaticResource Gray50Brush}"
                          ItemsSource="{Binding CustomerSummaries}"
                          SelectedItem="{Binding SelectedSummary}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CUSTOMER" Binding="{Binding Customer.Name}" Width="200"/>
                        <DataGridTextColumn Header="TOTAL CREDIT" Binding="{Binding TotalCredit, StringFormat='PKR {0:N0}'}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="CREDIT LIMIT" Binding="{Binding CreditLimit, StringFormat='PKR {0:N0}'}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="LAST PAYMENT" Binding="{Binding LastPaymentDate, StringFormat='{}{0:dd MMM yyyy}'}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Gray600Brush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="DAYS" Binding="{Binding DaysSincePayment}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="RISK" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RiskEmoji}" FontSize="16" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ACTIONS" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Pay"
                                                Padding="16,6"
                                                FontSize="12"
                                                Background="{StaticResource PrimaryBrush}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.RecordPaymentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Padding="8"
                                                Margin="4,0,0,0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.ViewCustomerKhataCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="Eye" Width="16" Height="16"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
