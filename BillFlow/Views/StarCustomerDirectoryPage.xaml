<UserControl x:Class="BillFlow.Views.StarCustomerDirectoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Notifications and Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <Border Background="#FEF2F2" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="{StaticResource DangerBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="8,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border Background="#F0FDF4" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="{StaticResource SuccessBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" Margin="8,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Star Customer Directory" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}" FontFamily="{StaticResource InterFontFamily}"/>
                    <TextBlock Text="Your favorite customers in one place." FontSize="14" Foreground="{StaticResource Gray500Brush}" Margin="0,8,0,0" FontFamily="{StaticResource InterFontFamily}"/>
                </StackPanel>

                <Button Grid.Column="1" 
                        Content="View All Customers"
                        Command="{Binding NavigateToCustomersCommand}"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="16,10"/>
            </Grid>
        </StackPanel>

        <!-- Search -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" 
                    BorderBrush="{StaticResource Gray200Brush}" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="14,10"
                    Width="360">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.06" Color="Black"/>
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Magnify" 
                                             Width="22" 
                                             Height="22"
                                             Foreground="{StaticResource Gray400Brush}"
                                             VerticalAlignment="Center"/>
                    <TextBox BorderThickness="0"
                             Background="Transparent"
                             Width="290"
                             Margin="10,0,0,0"
                             FontSize="15"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Column="1" 
                       Text="{Binding StarredCustomers.Count, StringFormat='{}{0} starred customers'}"
                       Style="{StaticResource BodyStyle}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"/>
        </Grid>

        <!-- Starred Customers Grid -->
        <Border Grid.Row="2" 
                Background="White"
                BorderBrush="{StaticResource Gray200Brush}"
                BorderThickness="1"
                CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <Border.Resources>
                <!-- DataGrid Row Style -->
                <Style x:Key="StarDataGridRowStyle" TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Height" Value="56"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F9FAFB"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EEF2FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
                <!-- DataGrid Header Style -->
                <Style x:Key="StarDataGridHeaderStyle" TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource Gray50Brush}"/>
                    <Setter Property="Foreground" Value="{StaticResource Gray700Brush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="16,14"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Gray200Brush}"/>
                    <Setter Property="Height" Value="52"/>
                </Style>
                <!-- Action Button Style -->
                <Style x:Key="StarActionButtonStyle" TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="8"/>
                    <Setter Property="Width" Value="36"/>
                    <Setter Property="Height" Value="36"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Gray100Brush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource Gray200Brush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Resources>
            <DataGrid AutoGenerateColumns="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding StarredCustomers}"
                      SelectedItem="{Binding SelectedCustomer}"
                      RowHeight="56"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      Background="Transparent"
                      RowStyle="{StaticResource StarDataGridRowStyle}"
                      ColumnHeaderStyle="{StaticResource StarDataGridHeaderStyle}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="56">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="32" 
                                        Height="32" 
                                        CornerRadius="10" 
                                        Background="#FEF3C7"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Star" 
                                                             Width="18" 
                                                             Height="18"
                                                             Foreground="#F59E0B"
                                                             VerticalAlignment="Center"
                                                             HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="CODE" Binding="{Binding CustomerCode}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="Foreground" Value="{StaticResource Gray800Brush}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="{StaticResource Gray600Brush}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="CREDIT LIMIT" Binding="{Binding CreditLimit, StringFormat='PKR {0:N0}'}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="{StaticResource Gray600Brush}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="TOTAL CREDIT" Binding="{Binding TotalCredit, StringFormat='PKR {0:N0}'}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="{StaticResource Gray800Brush}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="RISK" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding CreditRisk, Converter={StaticResource RiskToBrushConverter}}"
                                        CornerRadius="24"
                                        Padding="12,6"
                                        HorizontalAlignment="Left"
                                        MinWidth="80">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.1" Color="Black"/>
                                    </Border.Effect>
                                    <TextBlock Text="{Binding CreditRisk, Converter={StaticResource RiskToShortDisplayConverter}}"
                                               Foreground="{Binding CreditRisk, Converter={StaticResource RiskToForegroundConverter}}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="ACTIONS" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,0">
                                    <!-- View Button -->
                                    <Button Style="{StaticResource StarActionButtonStyle}"
                                            ToolTip="View Details"
                                            Margin="0,0,6,0"
                                            Command="{Binding DataContext.ViewCustomerDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="EyeOutline" Width="20" Height="20" Foreground="{StaticResource Gray500Brush}"/>
                                    </Button>
                                    <!-- Remove Star Button -->
                                    <Button Style="{StaticResource StarActionButtonStyle}"
                                            ToolTip="Remove from Stars"
                                            Command="{Binding DataContext.RemoveFromStarsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="StarRemove" Width="20" Height="20" Foreground="{StaticResource DangerBrush}"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
