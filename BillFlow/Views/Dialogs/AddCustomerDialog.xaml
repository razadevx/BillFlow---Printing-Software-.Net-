<Window x:Class="BillFlow.Views.Dialogs.AddCustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Gray50Brush}">

    <Border Style="{StaticResource GlassElevatedStyle}" Margin="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="{Binding DialogTitle}" Style="{StaticResource H2Style}" Margin="0,0,0,24"/>

            <!-- Form Fields -->
            <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewerStyle}">
                <StackPanel>
                    <!-- Name -->
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Customer Name" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Text=" *" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox Style="{StaticResource GlassInputStyle}" 
                                 Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Phone -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Phone Number" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource GlassInputStyle}" 
                                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Address -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Address" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource GlassInputStyle}" 
                                 Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Credit Limit -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Credit Limit (PKR)" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Style="{StaticResource GlassInputStyle}" 
                                 Text="{Binding CreditLimit, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,8,0,0">
                            <TextBox.FontFamily>
                                <StaticResource ResourceKey="JetBrainsMonoFontFamily"/>
                            </TextBox.FontFamily>
                        </TextBox>
                    </StackPanel>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Style="{StaticResource SecondaryButtonStyle}" 
                        Content="Cancel" 
                        Margin="0,0,8,0"
                        Click="CancelButton_Click"/>
                <Button Style="{StaticResource PrimaryButtonStyle}" 
                        Content="{Binding SaveButtonText}"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
