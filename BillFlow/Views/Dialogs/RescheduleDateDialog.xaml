<Window x:Class="BillFlow.Views.Dialogs.RescheduleDateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reschedule work order"
        Height="200" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Select new scheduled date" Style="{StaticResource BodyStyle}"/>
        <DatePicker x:Name="DatePickerControl" Grid.Row="1" Margin="0,12,0,0"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" IsCancel="True" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="OK" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
