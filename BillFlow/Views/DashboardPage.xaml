<UserControl x:Class="BillFlow.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">
            <!-- Metric Cards Row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Pending Card -->
                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL PENDING" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding TotalPendingAmount, StringFormat='PKR {0:N2}'}"
                                   Style="{StaticResource CurrencySmallStyle}"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="Across all customers"
                                   Style="{StaticResource BodySmallStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Today's Revenue Card -->
                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Margin="12,0,12,0">
                    <StackPanel>
                        <TextBlock Text="TODAY'S REVENUE" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding TodayRevenue, StringFormat='PKR {0:N2}'}"
                                   Style="{StaticResource CurrencySmallStyle}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock Text="Cash received today"
                                   Style="{StaticResource BodySmallStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Today's Work Card -->
                <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Margin="12,0,12,0">
                    <StackPanel>
                        <TextBlock Text="TODAY'S WORK" Style="{StaticResource LabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Style="{StaticResource CurrencySmallStyle}"
                                       Foreground="{StaticResource PrimaryBrush}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} / {1}">
                                        <Binding Path="TodayWorkDone"/>
                                        <Binding Path="TodayWorkTotal"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text=" scheduled"
                                       Style="{StaticResource H3Style}"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding TodayWorkDone}" Maximum="{Binding ProgressBarMaximum}" 
                                     Margin="0,8,0,0"
                                     Height="4"
                                     Background="{StaticResource Gray200Brush}"
                                     Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Active Customers Card -->
                <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="ACTIVE CUSTOMERS" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding ActiveCustomers}"
                                   Style="{StaticResource CurrencySmallStyle}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource WarningBrush}"/>
                        <TextBlock Text="With open credit"
                                   Style="{StaticResource BodySmallStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Pending Breakdown Section -->
            <Border Style="{StaticResource GlassCardStyle}" Margin="0,24,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Pending by Customer" Style="{StaticResource H3Style}"/>
                        <Button Grid.Column="1" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="View All"
                                Command="{Binding NavigateToKhataCommand}"/>
                    </Grid>

                    <!-- Data Grid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding TopCustomers}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{StaticResource Gray50Brush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CUSTOMER" Binding="{Binding Customer.Name}" Width="*"/>
                            <DataGridTextColumn Header="PENDING AMOUNT" Binding="{Binding TotalCredit, StringFormat='PKR {0:N2}'}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="LAST PAYMENT" Binding="{Binding LastPaymentDate, StringFormat='{}{0:dd MMM yyyy}'}" Width="150"/>
                            <DataGridTextColumn Header="DAYS" Binding="{Binding DaysSincePaymentDisplay}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="RISK" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RiskEmoji}" FontSize="16" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Today's Schedule Preview -->
            <Border Style="{StaticResource GlassCardStyle}" Margin="0,24,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Today's Schedule" Style="{StaticResource H3Style}"/>
                        <Button Grid.Column="1" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Full Schedule"
                                Command="{Binding NavigateToDailyScheduleCommand}"/>
                    </Grid>

                    <!-- Work Items -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TodaySchedulePreview}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GlassCardHoverableStyle}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource BodyStyle}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DetailLine}" Style="{StaticResource BodySmallStyle}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource PendingBadgeStyle}" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Order.WorkStatus}" Style="{StaticResource BodySmallStyle}" Foreground="{StaticResource WarningBrush}"/>
                                        </Border>
                                        <Button Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}" Content="Mark Done" Padding="16,6"
                                                Command="{Binding DataContext.MarkScheduleItemDoneCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
