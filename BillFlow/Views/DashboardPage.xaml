<UserControl x:Class="BillFlow.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Premium Metric Card Style -->
        <Style x:Key="PremiumMetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Gray200Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.06" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Glass Card Elevated Style -->
        <Style x:Key="PremiumGlassCardStyle" TargetType="Border" BasedOn="{StaticResource PremiumMetricCardStyle}">
            <Setter Property="Padding" Value="28"/>
        </Style>
        
        <!-- Pending Badge Style -->
        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#FEF3C7"/>
            <Setter Property="BorderBrush" Value="#FCD34D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource ModernScrollViewerStyle}" Background="{StaticResource Gray50Brush}">
        <StackPanel Margin="0,0,0,32">
            <!-- Notifications -->
            <Border Background="#FEF2F2" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="{StaticResource DangerBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="14"/>
                </StackPanel>
            </Border>
            <Border Background="#F0FDF4" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,20"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="{StaticResource SuccessBrush}" Width="20" Height="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="14"/>
                </StackPanel>
            </Border>

            <!-- Header Section -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0">
                    <TextBlock Text="Dashboard" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}" FontFamily="{StaticResource InterFontFamily}"/>
                    <TextBlock Text="Welcome back! Here's your printing business at a glance." FontSize="14" Foreground="{StaticResource Gray500Brush}" Margin="0,8,0,0" FontFamily="{StaticResource InterFontFamily}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource OutlineButtonStyle}" 
                            Content="+ New Customer"
                            Padding="18,12"
                            FontSize="14"
                            Margin="0,0,12,0"
                            Command="{Binding QuickAddCustomerCommand}"/>
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Content="+ New Work Order"
                            Padding="18,12"
                            FontSize="14"
                            Command="{Binding QuickCreateWorkOrderCommand}"/>
                </StackPanel>
            </Grid>

            <!-- Top Metrics Grid -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Pending Card -->
                <Border Grid.Column="0" Style="{StaticResource PremiumMetricCardStyle}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="TOTAL PENDING" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500Brush}" FontFamily="{StaticResource InterFontFamily}"/>
                        <TextBlock Grid.Row="1" Text="{Binding TotalPendingAmount, StringFormat='PKR {0:N0}'}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}" FontFamily="{StaticResource InterFontFamily}" Margin="0,12,0,0"/>
                        <TextBlock Grid.Row="2" Text="Across all customers" FontSize="13" Foreground="{StaticResource Gray500Brush}" FontFamily="{StaticResource InterFontFamily}" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <!-- Today's Revenue Card -->
                <Border Grid.Column="1" Style="{StaticResource PremiumMetricCardStyle}" Margin="12,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="TODAY'S REVENUE" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" FontFamily="{StaticResource InterFontFamily}"/>
                        <TextBlock Grid.Row="1" Text="{Binding TodayRevenue, StringFormat='PKR {0:N0}'}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" FontFamily="{StaticResource InterFontFamily}" Margin="0,12,0,0"/>
                        <TextBlock Grid.Row="2" Text="Cash received today" FontSize="13" Foreground="{StaticResource Gray500Brush}" FontFamily="{StaticResource InterFontFamily}" Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <!-- Today's Work Card with Circular Progress -->
                <Border Grid.Column="2" Style="{StaticResource PremiumMetricCardStyle}" Margin="12,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="TODAY'S WORK" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" FontFamily="{StaticResource InterFontFamily}"/>
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource Gray900Brush}" FontFamily="{StaticResource InterFontFamily}" HorizontalAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}/{1}">
                                        <Binding Path="TodayWorkDone"/>
                                        <Binding Path="TodayWorkTotal"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="scheduled" FontSize="13" Foreground="{StaticResource Gray500Brush}" FontFamily="{StaticResource InterFontFamily}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Active Customers Card -->
                <Border Grid.Column="3" Style="{StaticResource PremiumMetricCardStyle}" Margin="12,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="ACTIVE CUSTOMERS" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" FontFamily="{StaticResource InterFontFamily}"/>
                        <TextBlock Grid.Row="1" Text="{Binding ActiveCustomers}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" FontFamily="{StaticResource InterFontFamily}" Margin="0,12,0,0"/>
                        <TextBlock Grid.Row="2" Text="With open credit" FontSize="13" Foreground="{StaticResource Gray500Brush}" FontFamily="{StaticResource InterFontFamily}" Margin="0,6,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Pending by Customer Section -->
            <Border Style="{StaticResource PremiumGlassCardStyle}" Margin="0,0,0,32">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Pending by Customer" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Gray900Brush}" FontFamily="{StaticResource InterFontFamily}"/>
                            <TextBlock Text="Top customers with outstanding balances" FontSize="13" Foreground="{StaticResource Gray500Brush}" Margin="0,4,0,0" FontFamily="{StaticResource InterFontFamily}"/>
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="View All"
                                Padding="16,8"
                                FontSize="13"
                                Command="{Binding NavigateToKhataCommand}"/>
                    </Grid>

                    <!-- Data Grid - Borderless Table -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding TopCustomers}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              RowBackground="Transparent"
                              AlternatingRowBackground="Transparent"
                              RowHeight="52">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource Gray600Brush}"/>
                                <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Gray200Brush}"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Gray100Brush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F9FAFB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CUSTOMER" Binding="{Binding Customer.Name}" Width="*" MinWidth="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="Foreground" Value="{StaticResource Gray900Brush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="PENDING AMOUNT" Binding="{Binding TotalCredit, StringFormat='PKR {0:N0}'}" Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="LAST PAYMENT" Binding="{Binding LastPaymentDate, StringFormat='{}{0:dd MMM yyyy}'}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Foreground" Value="{StaticResource Gray600Brush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="DAYS" Binding="{Binding DaysSincePaymentDisplay}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Foreground" Value="{StaticResource Gray700Brush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="RISK" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RiskEmoji}" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="12,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Today's Schedule Section -->
            <Border Style="{StaticResource PremiumGlassCardStyle}" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Today's Schedule" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Gray900Brush}" FontFamily="{StaticResource InterFontFamily}"/>
                            <TextBlock Text="Work orders scheduled for today" FontSize="13" Foreground="{StaticResource Gray500Brush}" Margin="0,4,0,0" FontFamily="{StaticResource InterFontFamily}"/>
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Full Schedule"
                                Padding="16,8"
                                FontSize="13"
                                Command="{Binding NavigateToDailyScheduleCommand}"/>
                    </Grid>

                    <!-- Work Items -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TodaySchedulePreview}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="{StaticResource Gray200Brush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,12">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.04" Color="Black"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray900Brush}" FontFamily="{StaticResource InterFontFamily}"/>
                                            <TextBlock Text="{Binding DetailLine}" FontSize="13" Foreground="{StaticResource Gray500Brush}" Margin="0,4,0,0" FontFamily="{StaticResource InterFontFamily}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource StatusBadgeStyle}" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Text="Received" FontSize="12" FontWeight="SemiBold" Foreground="#B45309" FontFamily="{StaticResource InterFontFamily}"/>
                                        </Border>
                                        <Button Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}" Content="Mark Done" Padding="16,8" FontSize="13"
                                                Command="{Binding DataContext.MarkScheduleItemDoneCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
