<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors -->
    <Color x:Key="PrimaryIndigo">#4F46E5</Color>
    <Color x:Key="PrimaryIndigoDark">#4338CA</Color>
    <Color x:Key="PrimaryIndigoLight">#818CF8</Color>
    
    <!-- Status Colors -->
    <Color x:Key="SuccessEmerald">#10B981</Color>
    <Color x:Key="WarningAmber">#F59E0B</Color>
    <Color x:Key="DangerRose">#F43F5E</Color>
    
    <!-- Neutral Colors -->
    <Color x:Key="PureWhite">#FFFFFF</Color>
    <Color x:Key="PureBlack">#000000</Color>
    <Color x:Key="Gray50">#F9FAFB</Color>
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray700">#374151</Color>
    <Color x:Key="Gray800">#1F2937</Color>
    <Color x:Key="Gray900">#111827</Color>

    <!-- Solid Color Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryIndigo}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryIndigoDark}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryIndigoLight}"/>
    
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessEmerald}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningAmber}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerRose}"/>
    
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource PureWhite}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource PureBlack}"/>
    <SolidColorBrush x:Key="Gray50Brush" Color="{StaticResource Gray50}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray700Brush" Color="{StaticResource Gray700}"/>
    <SolidColorBrush x:Key="Gray800Brush" Color="{StaticResource Gray800}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>

    <!-- Status Badge Brushes -->
    <SolidColorBrush x:Key="PaidBackgroundBrush" Color="#10B981" Opacity="0.1"/>
    <SolidColorBrush x:Key="PaidForegroundBrush" Color="{StaticResource SuccessEmerald}"/>
    
    <SolidColorBrush x:Key="PendingBackgroundBrush" Color="#F59E0B" Opacity="0.1"/>
    <SolidColorBrush x:Key="PendingForegroundBrush" Color="{StaticResource WarningAmber}"/>
    
    <SolidColorBrush x:Key="OverdueBackgroundBrush" Color="#F43F5E" Opacity="0.1"/>
    <SolidColorBrush x:Key="OverdueForegroundBrush" Color="{StaticResource DangerRose}"/>

    <!-- Glassmorphism Brushes -->
    <SolidColorBrush x:Key="GlassBackgroundBrush" Color="White" Opacity="0.85"/>
    <SolidColorBrush x:Key="GlassElevatedBrush" Color="White" Opacity="0.95"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#4F46E5" Opacity="0.15"/>
    
    <!-- Sidebar Gradient -->
    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F9FAFB" Offset="1"/>
    </LinearGradientBrush>

    <!-- Button Brushes -->
    <SolidColorBrush x:Key="ButtonPrimaryBackground" Color="{StaticResource PrimaryIndigo}"/>
    <SolidColorBrush x:Key="ButtonPrimaryForeground" Color="White"/>
    <SolidColorBrush x:Key="ButtonSecondaryBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ButtonSecondaryForeground" Color="{StaticResource PrimaryIndigo}"/>
    <SolidColorBrush x:Key="ButtonSecondaryBorder" Color="{StaticResource PrimaryIndigo}"/>

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource Gray400}"/>

</ResourceDictionary>
