<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Font Families -->
    <FontFamily x:Key="InterFontFamily">pack://application:,,,/BillFlow;component/Fonts/#Inter, Segoe UI, Arial</FontFamily>
    <FontFamily x:Key="JetBrainsMonoFontFamily">pack://application:,,,/BillFlow;component/Fonts/#JetBrains Mono, Consolas, Courier New</FontFamily>

    <!-- Headings -->
    <Style x:Key="H1Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="LineHeight" Value="38"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="H2Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="LineHeight" Value="32"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="H3Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="LineHeight" Value="28"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Body Text -->
    <Style x:Key="BodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Regular"/>
        <Setter Property="LineHeight" Value="24"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <Style x:Key="BodySmallStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Regular"/>
        <Setter Property="LineHeight" Value="20"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <!-- Labels -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <Style x:Key="FormLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Numbers -->
    <Style x:Key="NumberStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="CurrencyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
        <Setter Property="FontSize" Value="42"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
    </Style>

    <Style x:Key="CurrencySmallStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource JetBrainsMonoFontFamily}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
    </Style>

    <!-- Navigation -->
    <Style x:Key="NavItemStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <Style x:Key="NavItemActiveStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
    </Style>

</ResourceDictionary>
