<Window x:Class="BillFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BillFlow.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="BillFlow — Printing Business Management"
        Height="800" Width="1400"
        MinHeight="640" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Gray50Brush}"
        FontFamily="{StaticResource InterFontFamily}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Style="{StaticResource GlassSidebarStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Brand -->
                <Border Grid.Row="0"
                        Padding="24,28,24,20"
                        BorderBrush="{StaticResource Gray200Brush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="12"
                                Background="{StaticResource PrimaryBrush}">
                            <materialDesign:PackIcon Kind="PrinterOutline" Width="26" Height="26"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="BillFlow" Style="{StaticResource H2Style}" FontSize="22"/>
                            <TextBlock Text="Print &amp; Credit" Style="{StaticResource BodySmallStyle}" Opacity="0.75" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="1"
                           Text="MENU"
                           Style="{StaticResource LabelStyle}"
                           Margin="24,16,24,8"
                           Opacity="0.55"/>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              Padding="12,0,12,20">
                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NavItem}">
                                <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Name}"
                                        HorizontalContentAlignment="Stretch">
                                    <Button.Tag>
                                        <MultiBinding Converter="{StaticResource RouteMatchConverter}">
                                            <Binding Path="DataContext.CurrentRoute" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="Name"/>
                                        </MultiBinding>
                                    </Button.Tag>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                            <Setter Property="Margin" Value="0,0,0,6"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFooter}" Value="True">
                                                    <Setter Property="Margin" Value="0,18,0,6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontSize="18"
                                                       Width="28"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                            <TextBlock Text="{Binding Title}"
                                                       FontFamily="{StaticResource InterFontFamily}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Main -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource GlassHeaderStyle}"
                    Padding="28,0,28,0"
                    MinHeight="76">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Margin="0,16,0,16">
                        <TextBlock Text="{Binding PageHeader}"
                                   Style="{StaticResource H2Style}"
                                   FontSize="22"/>
                        <TextBlock Text="Manage your printing business in one place"
                                   Style="{StaticResource BodySmallStyle}"
                                   Margin="0,4,0,0"
                                   Opacity="0.7"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Content="New customer"
                                Margin="0,0,10,0"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Customers"/>
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Content="New work order"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="WorkOrderCreate"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource Gray50Brush}"
                    Padding="28,20,28,28">
                <Frame x:Name="MainFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"/>
            </Border>
        </Grid>
    </Grid>
</Window>
